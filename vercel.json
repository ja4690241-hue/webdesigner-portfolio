{
  "buildCommand": "cd client && pnpm install && pnpm run build",
  "outputDirectory": "client/dist/public",
  "framework": "vite",
  "env": {
    "VITE_APP_TITLE": "Sado/Oja - Web Designer & Developer",
    "VITE_APP_LOGO": "https://webfolio-99ksjw7k.manus.space/logo.png"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
